<Window x:Class="ClipboardAI.Forms.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 ClipboardAI"
        Width="420" SizeToContent="Height" MinWidth="360"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="lblAppName" Grid.Row="0" FontSize="18" FontWeight="Bold"
                   Text="ClipboardAI" HorizontalAlignment="Center" Margin="0,0,0,4"/>

        <TextBlock x:Name="lblVersion" Grid.Row="1" FontSize="13"
                   Text="v0.0.3" HorizontalAlignment="Center" Foreground="Gray" Margin="0,0,0,16"/>

        <Separator Grid.Row="2" Margin="0,0,0,12"/>

        <Button x:Name="btnGitHub" Grid.Row="3" Content="访问 GitHub"
                Height="32" Margin="0,0,0,8" Click="BtnGitHub_Click"/>

        <Button x:Name="btnCheckUpdate" Grid.Row="4" Content="检查更新"
                Height="32" Margin="0,0,0,4" Click="BtnCheckUpdate_Click"/>

        <TextBlock x:Name="lblUpdateResult" Grid.Row="5" FontSize="12"
                   TextWrapping="Wrap" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,4,0,8"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
            <Button x:Name="btnClose" Content="关闭" Width="80" Height="30" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
