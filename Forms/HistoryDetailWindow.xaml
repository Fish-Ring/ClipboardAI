<Window x:Class="ClipboardAI.Forms.HistoryDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="winDetail"
        Title="处理详情"
        Width="650" SizeToContent="Height" MinHeight="350"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="lblHeader" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <GroupBox x:Name="grpOriginal" Grid.Row="1" Header="原文" Margin="0,0,0,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="txtOriginal" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                         MinHeight="60" MaxHeight="200" Margin="0,0,0,4"/>
                <Button x:Name="btnCopyOriginal" Grid.Row="1" Content="复制原文" Width="80" Height="26"
                        HorizontalAlignment="Right" Margin="0,0,0,2" Click="BtnCopyOriginal_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" x:Name="grpResult" Header="回答" Margin="0,0,0,6">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="txtResult" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                         MinHeight="80" MaxHeight="400" Margin="0,0,0,4"/>
                <Button x:Name="btnCopyResult" Grid.Row="1" Content="复制回答" Width="80" Height="26"
                        HorizontalAlignment="Right" Margin="0,0,0,2" Click="BtnCopyResult_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" x:Name="grpError" Header="错误" Margin="0,0,0,6" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="txtError" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                         MinHeight="40" MaxHeight="120" Margin="0,0,0,4" Foreground="Red"/>
                <Button x:Name="btnCopyError" Grid.Row="1" Content="复制错误" Width="80" Height="26"
                        HorizontalAlignment="Right" Margin="0,0,0,2" Click="BtnCopyError_Click"/>

            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="btnClose" Content="关闭" Width="80" Height="30" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
