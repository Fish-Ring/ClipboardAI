<Window x:Class="ClipboardAI.Forms.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="winConfig"
        Title="ClipboardAI 配置"
        Width="700" Height="600"
        MinWidth="600" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Grid Margin="0,0,0,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem x:Name="tabApi" Header="API 设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="15,10,15,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="lblApiUrl" Grid.Row="0" Grid.Column="0" Text="API 地址:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtApiBase" Margin="0,6"/>

                        <TextBlock x:Name="lblApiKey" Grid.Row="1" Grid.Column="0" Text="API Key:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="txtApiKey" Margin="0,6"/>

                        <TextBlock x:Name="lblModel" Grid.Row="2" Grid.Column="0" Text="模型:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtModel" Margin="0,6"/>

                        <TextBlock x:Name="lblMaxTokens" Grid.Row="3" Grid.Column="0" Text="Max Tokens:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtMaxTokens" Margin="0,6" MaxLength="7"/>

                        <TextBlock x:Name="lblTemperature" Grid.Row="4" Grid.Column="0" Text="Temperature:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,6">
                            <Slider x:Name="sldTemperature" Minimum="0" Maximum="2" SmallChange="0.1" LargeChange="0.2" Width="200" ValueChanged="SldTemperature_OnValueChanged"/>
                            <TextBlock x:Name="lblTemperatureVal" Text="0.3" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="32"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="tabPrompts" Header="Prompt 预设">
                <Grid Margin="15,10,15,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListBox Grid.Row="0" x:Name="lstPrompts" DisplayMemberPath="Name" SelectionChanged="OnPromptSelected" Margin="0,0,0,6"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnAddPrompt" Content="添加" Width="80" Height="30" Margin="0,0,6,0" Click="BtnAddPrompt_OnClick"/>
                            <Button x:Name="btnDeletePrompt" Content="删除" Width="80" Height="30" IsEnabled="False" Click="BtnDeletePrompt_OnClick"/>
                        </StackPanel>
                    </Grid>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"/>

                    <Grid Grid.Row="2" Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="lblPromptId" Grid.Row="0" Grid.Column="0" Text="ID:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtPromptId" Margin="0,6"/>

                        <TextBlock x:Name="lblPromptName" Grid.Row="1" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtPromptName" Margin="0,6"/>

                        <TextBlock x:Name="lblSystemPrompt" Grid.Row="2" Grid.Column="0" Text="System Prompt:" Margin="0,6,12,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSystemPrompt" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11" Margin="0,6"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem x:Name="tabHotkeys" Header="快捷键">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="15,10,15,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="lblEnableHotkey" Grid.Row="0" Grid.Column="0" Text="启用快捷键:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <CheckBox Grid.Row="0" Grid.Column="1" x:Name="chkHotkeyEnabled" Content="启用全局快捷键" VerticalAlignment="Center" Margin="0,6"/>

                        <TextBlock x:Name="lblModifiers" Grid.Row="1" Grid.Column="0" Text="修饰键:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,6">
                            <CheckBox x:Name="chkHotkeyAlt" Content="Alt" Margin="0,0,12,0"/>
                            <CheckBox x:Name="chkHotkeyCtrl" Content="Ctrl" Margin="0,0,12,0"/>
                            <CheckBox x:Name="chkHotkeyShift" Content="Shift"/>
                        </StackPanel>

                        <TextBlock x:Name="lblKey" Grid.Row="2" Grid.Column="0" Text="按键:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cboHotkeyKey" Margin="0,6" Width="120" HorizontalAlignment="Left"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="tabOther" Header="其他">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="15,10,15,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="lblMaxHistory" Grid.Row="0" Grid.Column="0" Text="历史记录上限:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtMaxHistory" Margin="0,6" Width="100" HorizontalAlignment="Left" MaxLength="4"/>

                        <TextBlock x:Name="lblNotifications" Grid.Row="1" Grid.Column="0" Text="显示通知:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="chkShowNotifications" Content="显示Windows托盘通知" VerticalAlignment="Center" Margin="0,6"/>

                        <TextBlock x:Name="lblClipboardMonitor" Grid.Row="2" Grid.Column="0" Text="剪贴板监控:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="chkClipboardMonitor" Content="监控剪贴板变化并自动处理" VerticalAlignment="Center" Margin="0,6"/>

                        <TextBlock x:Name="lblPlaySound" Grid.Row="3" Grid.Column="0" Text="完成提示音:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="chkPlaySound" Content="AI返回结果后播放提示音" VerticalAlignment="Center" Margin="0,6"/>

                        <TextBlock x:Name="lblLanguage" Grid.Row="4" Grid.Column="0" Text="语言:" VerticalAlignment="Center" Margin="0,6,12,6"/>
                        <ComboBox x:Name="cboLanguage" Grid.Row="4" Grid.Column="1" Margin="0,6" Width="120" HorizontalAlignment="Left"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1" Margin="15,5,15,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnSave" Grid.Column="1" Content="保存" Width="80" Height="30" Margin="0,0,6,0" Click="BtnSave_OnClick"/>
            <Button x:Name="btnCancel" Grid.Column="2" Content="取消" Width="80" Height="30" Click="BtnCancel_OnClick"/>
        </Grid>
    </Grid>
</Window>
